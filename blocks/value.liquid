{% doc %}
  Renders a single numbered value proposition tile.

  @example
  {% content_for 'block', type: 'value', id: 'value-1' %}
{% enddoc %}

<div class="value" {{ block.shopify_attributes }}>
  <div class="value__number">{{ block.settings.number }}</div>
  <div class="value__title">{{ block.settings.title }}</div>
  <p class="value__body">{{ block.settings.body }}</p>
</div>

{% stylesheet %}
  .value {
    padding: 2.25rem 2rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    transition: border-color 0.25s ease, transform 0.25s ease;
  }

  .value:hover {
    border-color: var(--color-gold);
    transform: translateY(-4px);
  }

  .value__number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: rgba(217, 185, 106, 0.1);
    border: 1px solid rgba(217, 185, 106, 0.3);
    font-family: var(--font-heading--family);
    font-size: 15px;
    font-weight: 600;
    color: var(--color-gold);
    margin-bottom: 1.25rem;
  }

  .value__title {
    font-family: var(--font-heading--family);
    font-size: 19px;
    font-weight: 500;
    margin-bottom: 0.75rem;
  }

  .value__body {
    color: var(--color-secondary-text);
    font-size: 15px;
    line-height: 1.7;
    margin: 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.value",
  "settings": [
    {
      "type": "text",
      "id": "number",
      "label": "t:labels.number",
      "default": "01"
    },
    {
      "type": "text",
      "id": "title",
      "label": "t:labels.title",
      "default": "Value title"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "t:labels.body",
      "default": "Value description."
    }
  ],
  "presets": [
    {
      "name": "t:general.value"
    }
  ]
}
{% endschema %}
