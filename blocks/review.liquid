{% doc %}
  Renders a single customer review row.

  @example
  {% content_for 'block', type: 'review', id: 'review-1' %}
{% enddoc %}

<div class="review" {{ block.shopify_attributes }}>
  <div class="review__avatar-and-body">
    <div class="review__avatar">{{ block.settings.initial }}</div>
    <div class="review__body">
      <div class="review__stars">
        {%- for i in (1..5) -%}
          {%- if i <= block.settings.stars -%}&#9733;{%- else -%}&#9734;{%- endif -%}
        {%- endfor -%}
      </div>
      <div class="review__meta">{{ block.settings.name }} &middot; {{ block.settings.product }}</div>
      <div class="review__title">{{ block.settings.title }}</div>
      <p class="review__quote">{{ block.settings.quote }}</p>
    </div>
  </div>
  <div class="review__date">{{ block.settings.date }}</div>
</div>

{% stylesheet %}
  .review {
    display: flex;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.75rem 0;
    border-bottom: 1px solid rgba(196, 161, 90, 0.1);
  }

  .review__avatar-and-body {
    display: flex;
    gap: 1rem;
  }

  .review__avatar {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: var(--color-background);
    border: 1px solid rgba(196, 161, 90, 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-muted);
    font-size: 14px;
    flex-shrink: 0;
  }

  .review__stars {
    color: var(--color-gold-dark);
    font-size: 13px;
    letter-spacing: 0.08em;
    margin-bottom: 0.375rem;
  }

  .review__meta {
    color: var(--color-muted);
    font-size: 13px;
    margin-bottom: 0.5rem;
  }

  .review__title {
    font-size: 15px;
    color: var(--color-foreground);
    margin-bottom: 0.375rem;
  }

  .review__quote {
    color: var(--color-secondary-text);
    font-size: 14px;
    line-height: 1.7;
    margin: 0;
    max-width: 640px;
  }

  .review__date {
    color: #5c564c;
    font-size: 12px;
    white-space: nowrap;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.review",
  "settings": [
    {
      "type": "text",
      "id": "initial",
      "label": "t:labels.initial",
      "default": "A"
    },
    {
      "type": "range",
      "id": "stars",
      "label": "t:labels.stars",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 5
    },
    {
      "type": "text",
      "id": "name",
      "label": "t:labels.name",
      "default": "Customer name"
    },
    {
      "type": "text",
      "id": "product",
      "label": "t:labels.product_name",
      "default": "Product"
    },
    {
      "type": "text",
      "id": "title",
      "label": "t:labels.title",
      "default": "Review title"
    },
    {
      "type": "textarea",
      "id": "quote",
      "label": "t:labels.quote",
      "default": "Review text."
    },
    {
      "type": "text",
      "id": "date",
      "label": "t:labels.date",
      "default": "01/01/2026"
    }
  ],
  "presets": [
    {
      "name": "t:general.review"
    }
  ]
}
{% endschema %}
