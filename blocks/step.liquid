{% doc %}
  Renders a single numbered step in the "how to use" ritual grid.

  @example
  {% content_for 'block', type: 'step', id: 'step-1' %}
{% enddoc %}

<div class="step" {{ block.shopify_attributes }}>
  <div class="step__circle" style="animation: step-glow-{{ block.settings.glow_order }} 6s ease-in-out infinite;">
    {%- if block.settings.icon != blank -%}
      {{ block.settings.icon | image_url: width: 60 | image_tag: class: 'step__icon', alt: '', loading: 'lazy' }}
    {%- elsif block.settings.fallback_asset != blank -%}
      <img class="step__icon" src="{{ block.settings.fallback_asset | asset_url }}" alt="" width="26" height="26" loading="lazy">
    {%- endif -%}
  </div>
  <div class="step__title">{{ block.settings.title }}</div>
  <div class="step__body">{{ block.settings.body }}</div>
</div>

{% stylesheet %}
  .step {
    text-align: center;
    padding: 0 1.5rem;
    position: relative;
  }

  .step__circle {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.5rem;
    position: relative;
    z-index: 1;
  }

  @keyframes step-glow-1 {
    0%, 4% {
      background: #fff;
      box-shadow: none;
    }
    10%, 100% {
      background: var(--color-gold-dark);
      box-shadow: 0 12px 30px rgba(184, 134, 11, 0.35);
    }
  }

  @keyframes step-glow-2 {
    0%, 30% {
      background: #fff;
      box-shadow: none;
    }
    38%, 100% {
      background: var(--color-gold-dark);
      box-shadow: 0 12px 30px rgba(184, 134, 11, 0.35);
    }
  }

  @keyframes step-glow-3 {
    0%, 58% {
      background: #fff;
      box-shadow: none;
    }
    66%, 100% {
      background: var(--color-gold-dark);
      box-shadow: 0 12px 30px rgba(184, 134, 11, 0.35);
    }
  }

  .step__icon {
    width: 26px;
    height: 26px;
    object-fit: contain;
  }

  .step__title {
    font-size: 17px;
    margin-bottom: 0.625rem;
  }

  .step__body {
    color: var(--color-muted);
    font-size: 14px;
    line-height: 1.7;
  }

  @media (max-width: 700px) {
    .step {
      display: grid;
      grid-template-columns: 58px 1fr;
      column-gap: 1.25rem;
      row-gap: 0;
      text-align: left;
      padding: 0;
    }

    .step__circle {
      grid-column: 1;
      grid-row: 1 / span 2;
      width: 52px;
      height: 52px;
      margin: 0;
      align-self: start;
    }

    .step__title {
      grid-column: 2;
      grid-row: 1;
      align-self: center;
      margin-bottom: 0;
    }

    .step__body {
      grid-column: 2;
      grid-row: 2;
      margin-top: 0.5rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.step",
  "settings": [
    {
      "type": "image_picker",
      "id": "icon",
      "label": "t:labels.icon"
    },
    {
      "type": "text",
      "id": "fallback_asset",
      "label": "t:labels.fallback_asset",
      "info": "t:labels.fallback_asset_info"
    },
    {
      "type": "text",
      "id": "title",
      "label": "t:labels.title",
      "default": "Step title"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "t:labels.body",
      "default": "Step description."
    },
    {
      "type": "select",
      "id": "glow_order",
      "label": "t:labels.glow_order",
      "options": [
        { "value": "1", "label": "t:options.glow_order.first" },
        { "value": "2", "label": "t:options.glow_order.second" },
        { "value": "3", "label": "t:options.glow_order.third" }
      ],
      "default": "1"
    }
  ],
  "presets": [
    {
      "name": "t:general.step"
    }
  ]
}
{% endschema %}
