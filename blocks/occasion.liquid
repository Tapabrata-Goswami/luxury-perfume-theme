{% doc %}
  Renders a single occasion tile (e.g. Office, Date Night) for the occasions section.

  @example
  {% content_for 'block', type: 'occasion', id: 'occasion-1' %}
{% enddoc %}

<div class="occasion" {{ block.shopify_attributes }}>
  <div class="occasion__title">{{ block.settings.title }}</div>
  {%- if block.settings.body != blank -%}
    <p class="occasion__body">{{ block.settings.body }}</p>
  {%- endif -%}
</div>

{% stylesheet %}
  .occasion {
    padding: 2rem 1.75rem;
    border: 1px solid var(--color-border);
    text-align: center;
  }

  .occasion__title {
    font-family: var(--font-heading--family);
    font-weight: 500;
    font-size: 21px;
    color: var(--color-gold);
    margin-bottom: 0.75rem;
  }

  .occasion__body {
    color: var(--color-secondary-text);
    font-size: 14px;
    line-height: 1.7;
    margin: 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.occasion",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "t:labels.title",
      "default": "Office"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "t:labels.body",
      "default": "A refined, subtle presence for the workday."
    }
  ],
  "presets": [
    {
      "name": "t:general.occasion"
    }
  ]
}
{% endschema %}
