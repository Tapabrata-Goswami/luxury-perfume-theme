{% doc %}
  Renders a single internal-linking tile pointing at a collection URL.

  @example
  {% content_for 'block', type: 'collection-link', id: 'collection-link-1' %}
{% enddoc %}

<a href="{{ block.settings.url | default: '#' }}" class="collection-link" {{ block.shopify_attributes }}>
  <span class="collection-link__label">{{ block.settings.label }}</span>
  <span class="collection-link__arrow">&rarr;</span>
</a>

{% stylesheet %}
  .collection-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 1.125rem 1.5rem;
    border: 1px solid var(--color-border);
    color: inherit;
    text-decoration: none;
    transition: border-color 0.25s ease, color 0.25s ease;
  }

  .collection-link:hover {
    border-color: var(--color-gold);
    color: var(--color-gold);
  }

  .collection-link__label {
    font-size: 14px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .collection-link__arrow {
    color: var(--color-gold);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.collection_link",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "t:labels.label",
      "default": "Best Sellers"
    },
    {
      "type": "url",
      "id": "url",
      "label": "t:labels.url"
    }
  ],
  "presets": [
    {
      "name": "t:general.collection_link"
    }
  ]
}
{% endschema %}
