{% doc %}
  Renders a single square photo tile for the Instagram marquee.

  @example
  {% content_for 'block', type: 'instagram-image', id: 'instagram-image-1' %}
{% enddoc %}

<a
  href="{{ block.settings.link | default: '#' }}"
  target="_blank"
  rel="noopener"
  class="instagram-tile"
  {{ block.shopify_attributes }}
>
  {%- if block.settings.image != blank -%}
    {{ block.settings.image | image_url: width: 520 | image_tag: sizes: '260px', class: 'instagram-tile__img', alt: block.settings.image.alt | default: '' }}
  {%- elsif block.settings.fallback_asset != blank -%}
    <img
      class="instagram-tile__img"
      src="{{ block.settings.fallback_asset | asset_url }}"
      alt=""
      width="260"
      height="260"
      loading="lazy"
    >
  {%- endif -%}
</a>

{% stylesheet %}
  .instagram-tile {
    display: block;
    width: 260px;
    height: 260px;
    flex: 0 0 260px;
    overflow: hidden;
    position: relative;
    margin-right: 1rem;
    border: 1px solid rgba(196, 161, 90, 0.2);
  }

  .instagram-tile__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.instagram_image",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:labels.image"
    },
    {
      "type": "url",
      "id": "link",
      "label": "t:labels.link_url"
    },
    {
      "type": "text",
      "id": "fallback_asset",
      "label": "t:labels.fallback_asset",
      "info": "t:labels.fallback_asset_info"
    }
  ],
  "presets": [
    {
      "name": "t:general.instagram_image"
    }
  ]
}
{% endschema %}
