{% doc %}
  Renders a single icon + title tile for the features row.

  @example
  {% content_for 'block', type: 'feature', id: 'feature-1' %}
{% enddoc %}

<div class="feature" {{ block.shopify_attributes }}>
  <div class="feature__icon-badge">
    {%- if block.settings.icon != blank -%}
      {{ block.settings.icon | image_url: width: 60 | image_tag: class: 'feature__icon', alt: '', loading: 'lazy' }}
    {%- elsif block.settings.fallback_asset != blank -%}
      <img class="feature__icon" src="{{ block.settings.fallback_asset | asset_url }}" alt="" width="28" height="28" loading="lazy">
    {%- endif -%}
  </div>
  <div class="feature__title">{{ block.settings.title }}</div>
</div>

{% stylesheet %}
  .feature {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    flex: 0 0 auto;
    width: 160px;
  }

  .feature__icon-badge {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1.5px solid var(--color-background);
    margin-bottom: 0.875rem;
    transition: transform 0.25s ease;
  }

  .feature:hover .feature__icon-badge {
    transform: scale(1.06);
  }

  .feature__icon {
    width: 28px;
    height: 28px;
    object-fit: contain;
  }

  .feature__title {
    color: var(--color-background);
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  @media (max-width: 700px) {
    .feature {
      width: 130px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.feature",
  "settings": [
    {
      "type": "image_picker",
      "id": "icon",
      "label": "t:labels.icon"
    },
    {
      "type": "text",
      "id": "fallback_asset",
      "label": "t:labels.fallback_asset",
      "info": "t:labels.fallback_asset_info"
    },
    {
      "type": "text",
      "id": "title",
      "label": "t:labels.title",
      "default": "Feature"
    }
  ],
  "presets": [
    {
      "name": "t:general.feature"
    }
  ]
}
{% endschema %}
