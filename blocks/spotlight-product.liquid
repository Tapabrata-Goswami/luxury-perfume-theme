{% doc %}
  Renders a single best-selling product card with a marketing blurb, linking
  to the real product page for internal linking / SEO purposes.

  @example
  {% content_for 'block', type: 'spotlight-product', id: 'spotlight-1' %}
{% enddoc %}

<div class="spotlight-product" {{ block.shopify_attributes }}>
  {%- if block.settings.product != blank -%}
    <a href="{{ block.settings.product.url }}" class="spotlight-product__image">
      {%- if block.settings.product.featured_image != blank -%}
        {{ block.settings.product.featured_image | image_url: width: 600 | image_tag: sizes: '(min-width: 900px) 30vw, 90vw', alt: block.settings.product.featured_image.alt | default: block.settings.product.title }}
      {%- endif -%}
    </a>
    <a href="{{ block.settings.product.url }}" class="spotlight-product__title-link">
      <h3 class="spotlight-product__title">{{ block.settings.product.title }}</h3>
    </a>
    <div class="spotlight-product__price">{{ block.settings.product.price | money }}</div>
  {%- endif -%}
  {%- if block.settings.body != blank -%}
    <p class="spotlight-product__body">{{ block.settings.body }}</p>
  {%- endif -%}
  {%- if block.settings.product != blank -%}
    <a href="{{ block.settings.product.url }}" class="spotlight-product__link">{{ 'product.view_details' | t }} &rarr;</a>
  {%- endif -%}
</div>

{% stylesheet %}
  .spotlight-product {
    text-align: center;
  }

  .spotlight-product__image {
    display: block;
    aspect-ratio: 1 / 1.05;
    overflow: hidden;
    margin-bottom: 1.375rem;
    background: var(--color-surface);
    border-radius: 4px;
  }

  .spotlight-product__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .spotlight-product__image:hover img {
    transform: scale(1.05);
  }

  .spotlight-product__title-link {
    text-decoration: none;
    color: inherit;
  }

  .spotlight-product__title {
    font-family: var(--font-heading--family);
    font-weight: 500;
    font-size: 24px;
    margin: 0 0 0.375rem;
  }

  .spotlight-product__price {
    color: var(--color-gold);
    font-size: 15px;
    margin-bottom: 1rem;
  }

  .spotlight-product__body {
    color: var(--color-secondary-text);
    font-size: 14px;
    line-height: 1.7;
    max-width: 340px;
    margin: 0 auto 1rem;
  }

  .spotlight-product__link {
    color: var(--color-gold);
    text-decoration: none;
    font-size: 13px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border-bottom: 1px solid var(--color-gold);
    padding-bottom: 0.2rem;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.spotlight_product",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "t:labels.product"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "t:labels.body",
      "default": "A best-selling fragrance oil loved for its longevity and rich projection."
    }
  ],
  "presets": [
    {
      "name": "t:general.spotlight_product"
    }
  ]
}
{% endschema %}
