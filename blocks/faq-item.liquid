{% doc %}
  Renders a single question/answer accordion row for the FAQ section.

  @example
  {% content_for 'block', type: 'faq-item', id: 'faq-item-1' %}
{% enddoc %}

<details class="faq-item" {{ block.shopify_attributes }}>
  <summary class="faq-item__question">
    {{ block.settings.question }}
    <span class="faq-item__icon" aria-hidden="true"></span>
  </summary>
  <div class="faq-item__answer">{{ block.settings.answer }}</div>
</details>

{% stylesheet %}
  .faq-item {
    border-top: 1px solid var(--color-border);
    padding: 1.375rem 0;
  }

  .faq-item:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  .faq-item__question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    font-size: 16px;
    cursor: pointer;
    list-style: none;
  }

  .faq-item__question::-webkit-details-marker {
    display: none;
  }

  .faq-item__icon {
    flex-shrink: 0;
    width: 12px;
    height: 12px;
    position: relative;
  }

  .faq-item__icon::before,
  .faq-item__icon::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    background: var(--color-gold);
    transform: translate(-50%, -50%);
    transition: transform 0.25s ease;
  }

  .faq-item__icon::before {
    width: 12px;
    height: 1.5px;
  }

  .faq-item__icon::after {
    width: 1.5px;
    height: 12px;
  }

  .faq-item[open] .faq-item__icon::after {
    transform: translate(-50%, -50%) rotate(90deg) scaleY(0);
  }

  .faq-item__answer {
    color: var(--color-muted);
    font-size: 14px;
    line-height: 1.7;
    margin-top: 0.875rem;
    max-width: 640px;
  }

  .faq-item__answer p {
    margin: 0 0 0.875rem;
  }

  .faq-item__answer p:last-child {
    margin-bottom: 0;
  }

  .faq-item__answer ul {
    margin: 0 0 0.875rem;
    padding-left: 1.125rem;
  }

  .faq-item__answer ul:last-child {
    margin-bottom: 0;
  }

  .faq-item__answer li {
    margin-bottom: 0.375rem;
  }

  .faq-item__answer li::marker {
    color: var(--color-gold);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.faq_item",
  "settings": [
    {
      "type": "text",
      "id": "question",
      "label": "t:labels.question",
      "default": "Question"
    },
    {
      "type": "richtext",
      "id": "answer",
      "label": "t:labels.answer",
      "default": "<p>Answer.</p>"
    }
  ],
  "presets": [
    {
      "name": "t:general.faq_item"
    }
  ]
}
{% endschema %}
