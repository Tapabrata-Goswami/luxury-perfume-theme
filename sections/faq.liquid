<div class="faq" id="faqs">
  {%- if section.settings.eyebrow != blank -%}
    <div class="faq__eyebrow">{{ section.settings.eyebrow }}</div>
  {%- endif -%}
  {%- if section.settings.heading != blank -%}
    <h2 class="faq__heading">{{ section.settings.heading }}</h2>
  {%- endif -%}
  <div class="faq__list">
    {%- for block in section.blocks -%}
      {% render block %}
    {%- endfor -%}
  </div>
</div>

{% stylesheet %}
  .faq {
    padding: 5.625rem 4rem;
    border-top: 1px solid var(--color-border);
    scroll-margin-top: 2rem;
  }

  .faq__eyebrow {
    color: var(--color-gold);
    font-size: 13px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    text-align: left;
    margin-bottom: 1rem;
  }

  .faq__heading {
    font-family: var(--font-heading--family);
    font-weight: 500;
    font-size: 36px;
    text-align: left;
    margin: 0 0 3rem;
  }

  .faq__list {
    display: flex;
    flex-direction: column;
  }

  @media (max-width: 700px) {
    .faq {
      padding: 4rem 1.5rem;
    }

    .faq__heading {
      font-size: 28px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.faq",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow",
      "default": "Questions"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Frequently Asked Questions"
    }
  ],
  "blocks": [
    {
      "type": "faq-category"
    },
    {
      "type": "faq-item"
    }
  ],
  "presets": [
    {
      "name": "t:general.faq",
      "blocks": [
        { "type": "faq-item", "settings": { "question": "Are these fragrances the same as the designer originals?", "answer": "<p>No. Each fragrance oil is independently formulated and inspired by a well-known scent profile. We are not affiliated with, and do not claim to be, the original fragrance houses.</p>" } },
        { "type": "faq-item", "settings": { "question": "How long does a bottle last?", "answer": "<p>With normal daily use, a 10ml roll-on typically lasts 2–3 months. Because these are concentrated oils, a little goes a long way.</p>" } },
        { "type": "faq-item", "settings": { "question": "How do I apply the oil?", "answer": "<p>Roll a small amount onto pulse points — wrists, neck, and behind the ears — where body heat helps the fragrance develop throughout the day.</p>" } },
        { "type": "faq-item", "settings": { "question": "Do you ship internationally?", "answer": "<p>We currently ship within the regions listed at checkout. Shipping times and rates are calculated automatically based on your address.</p>" } },
        { "type": "faq-item", "settings": { "question": "What is your return policy?", "answer": "<p>Unopened items can be returned within 30 days of delivery. Please see our Refund Policy page for full details.</p>" } }
      ]
    }
  ]
}
{% endschema %}
