<footer class="site-footer full-width">
  <div class="site-footer__bar" style="--bar-edge-color: {{ settings.gold_dark_color | color_darken: 15 }};"></div>

  <div class="site-footer__watermark" aria-hidden="true">
    <img
      src="{{ 'logo-monogram.jpg' | asset_url }}"
      alt=""
      width="600"
      height="600"
      loading="lazy"
    >
  </div>

  <div class="site-footer__inner">
    <div class="site-footer__grid">
      <div class="site-footer__image">
        {%- if section.settings.lifestyle_image != blank -%}
          {{ section.settings.lifestyle_image | image_url: width: 900 | image_tag: sizes: '45vw', class: 'site-footer__image-tag', alt: '' }}
        {%- else -%}
          <img
            class="site-footer__image-tag"
            src="{{ 'footer-lifestyle.jpg' | asset_url }}"
            alt=""
            width="900"
            height="1000"
            loading="lazy"
          >
        {%- endif -%}
      </div>

      <div class="site-footer__columns">
        <div class="site-footer__column">
          <div class="site-footer__column-title">{{ 'footer.pages' | t }}</div>
          <div class="site-footer__links">
            {%- for link in section.settings.pages_menu.links -%}
              <a href="{{ link.url }}">{{ link.title }}</a>
            {%- endfor -%}
          </div>
        </div>

        <div class="site-footer__column">
          <div class="site-footer__column-title">{{ 'footer.support' | t }}</div>
          <div class="site-footer__links">
            {%- for link in section.settings.support_menu.links -%}
              <a href="{{ link.url }}">{{ link.title }}</a>
            {%- endfor -%}
          </div>
        </div>

        <div class="site-footer__column">
          <div class="site-footer__column-title">{{ 'footer.social' | t }}</div>
          <div class="site-footer__social-icons">
            <a href="{{ settings.social_instagram_url | default: '#' }}" target="_blank" rel="noopener" aria-label="{{ 'footer.instagram' | t }}" class="site-footer__social-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="3" width="18" height="18" rx="5" /><circle cx="12" cy="12" r="4" /><circle cx="17.5" cy="6.5" r="0.9" fill="currentColor" stroke="none" /></svg>
            </a>
            <a href="{{ settings.social_facebook_url | default: '#' }}" target="_blank" rel="noopener" aria-label="{{ 'footer.facebook' | t }}" class="site-footer__social-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M15 8h2V4h-2a4 4 0 0 0-4 4v2H9v4h2v6h4v-6h2.5l.5-4H15V8Z" /></svg>
            </a>
            <a href="{{ settings.social_tiktok_url | default: '#' }}" target="_blank" rel="noopener" aria-label="{{ 'footer.tiktok' | t }}" class="site-footer__social-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M14 3v11.5a3.5 3.5 0 1 1-3-3.46" /><path d="M14 3a5.5 5.5 0 0 0 5.5 5.5" /></svg>
            </a>
          </div>

          <div class="site-footer__column-title site-footer__column-title--contact">{{ 'footer.contact' | t }}</div>
          <div class="site-footer__contact">
            {%- if section.settings.contact_email != blank -%}
              <div class="site-footer__contact-row">
                <svg class="site-footer__contact-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="5" width="18" height="14" rx="2" /><path d="m3 7 9 6 9-6" /></svg>
                <a href="mailto:{{ section.settings.contact_email }}">{{ section.settings.contact_email }}</a>
              </div>
            {%- endif -%}
            {%- if section.settings.contact_address != blank -%}
              <div class="site-footer__contact-row">
                <svg class="site-footer__contact-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 21s7-6.5 7-11a7 7 0 1 0-14 0c0 4.5 7 11 7 11Z" /><circle cx="12" cy="10" r="2.5" /></svg>
                <div class="site-footer__contact-address">{{ section.settings.contact_address }}</div>
              </div>
            {%- endif -%}
            {%- if settings.social_whatsapp_number != blank -%}
              {%- assign whatsapp_digits = settings.social_whatsapp_number | remove: ' ' | remove: '(' | remove: ')' | remove: '-' | remove: '+' -%}
              <div class="site-footer__contact-row">
                <svg class="site-footer__contact-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 3a9 9 0 0 0-7.8 13.5L3 21l4.6-1.2A9 9 0 1 0 12 3Z" /><path d="M8.5 8.5c-.3.6-.5 1.3-.2 2.3.5 1.8 2.9 4.2 4.7 4.7 1 .3 1.7.1 2.3-.2.5-.2.9-.9.7-1.4l-.5-1a.9.9 0 0 0-1-.4l-.9.3a.7.7 0 0 1-.7-.2 6 6 0 0 1-1.9-1.9.7.7 0 0 1-.2-.7l.3-.9a.9.9 0 0 0-.4-1l-1-.5c-.5-.2-1.2.2-1.4.7Z" /></svg>
                <a href="https://wa.me/{{ whatsapp_digits }}" target="_blank" rel="noopener">{{ settings.social_whatsapp_number }}</a>
              </div>
            {%- endif -%}
          </div>
        </div>

        <div class="site-footer__column">
          <div class="site-footer__column-title">{{ 'footer.newsletter' | t }}</div>
          <p class="site-footer__newsletter-text">{{ 'footer.newsletter_text' | t }}</p>
          {%- form 'customer', class: 'site-footer__newsletter-form' -%}
            <input type="hidden" name="contact[tags]" value="newsletter">
            {%- if form.posted_successfully? -%}
              <p class="site-footer__newsletter-success">{{ 'footer.newsletter_success' | t }}</p>
            {%- else -%}
              <div class="site-footer__newsletter-field">
                <label class="visually-hidden" for="FooterNewsletterEmail">{{ 'footer.newsletter_placeholder' | t }}</label>
                <input
                  type="email"
                  id="FooterNewsletterEmail"
                  class="site-footer__newsletter-input"
                  name="contact[email]"
                  placeholder="{{ 'footer.newsletter_placeholder' | t }}"
                  required
                >
                <button type="submit" class="site-footer__newsletter-submit" aria-label="{{ 'footer.newsletter_submit' | t }}">&rarr;</button>
              </div>
            {%- endif -%}
          {%- endform -%}
        </div>
      </div>

      <div class="site-footer__bottom">
        <div class="site-footer__wordmark">{{ section.settings.wordmark_text }}</div>
        <div class="site-footer__meta">
          <div>{{ section.settings.tagline }}</div>
          <div class="site-footer__copyright">{{ section.settings.copyright_text }}</div>
        </div>
      </div>
    </div>
  </div>
</footer>

{% stylesheet %}
  .site-footer {
    position: relative;
    overflow: hidden;
    background: var(--color-surface-dark);
  }

  .site-footer__bar {
    position: relative;
    z-index: 1;
    height: 4px;
    background: linear-gradient(90deg, var(--bar-edge-color), var(--color-gold), var(--bar-edge-color));
  }

  .site-footer__watermark {
    position: absolute;
    z-index: 0;
    bottom: -140px;
    right: -100px;
    width: 480px;
    height: 480px;
    pointer-events: none;
  }

  .site-footer__watermark img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    border-radius: 50%;
    filter: blur(6px);
    opacity: 0.1;
  }

  .site-footer__inner {
    position: relative;
    z-index: 1;
    max-width: var(--page-width);
    margin-inline: auto;
    padding: 0 4rem;
  }

  .site-footer__grid {
    display: grid;
    grid-template-columns: 0.9fr 1.5fr;
    gap: 2.5rem;
  }

  .site-footer__image {
    min-height: 360px;
    overflow: hidden;
  }

  .site-footer__image-tag {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .site-footer__columns {
    padding: 3.5rem 0 2.5rem;
    display: grid;
    grid-template-columns: 1fr 1fr 1.1fr 1.3fr;
    gap: 2rem;
  }

  .site-footer__column-title {
    font-family: var(--font-heading--family);
    font-size: 15px;
    letter-spacing: 0.06em;
    color: var(--color-gold);
    margin-bottom: 1.375rem;
  }

  .site-footer__column-title--contact {
    margin-top: 2rem;
  }

  .site-footer__links {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .site-footer__links a {
    color: #c9beac;
    text-decoration: none;
    font-size: 14px;
  }

  .site-footer__contact {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .site-footer__contact-row {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
  }

  .site-footer__contact-icon {
    flex-shrink: 0;
    color: var(--color-gold);
    margin-top: 0.125rem;
  }

  .site-footer__contact a {
    color: #c9beac;
    text-decoration: none;
    font-size: 14px;
  }

  .site-footer__contact-address {
    color: #c9beac;
    font-size: 14px;
    line-height: 1.6;
    max-width: 200px;
  }

  .site-footer__social-icons {
    display: flex;
    flex-wrap: wrap;
    gap: 0.875rem;
  }

  .site-footer__social-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border: 1px solid var(--color-gold);
    border-radius: 50%;
    color: var(--color-gold);
    background: color-mix(in srgb, var(--color-gold) 12%, transparent);
    transition: background-color 0.2s ease, color 0.2s ease, transform 0.2s ease;
  }

  .site-footer__social-icon:hover {
    color: var(--color-background);
    background: var(--color-gold);
    transform: translateY(-2px);
  }

  .site-footer__newsletter-text {
    color: #c9beac;
    font-size: 14px;
    line-height: 1.6;
    margin: 0 0 1.125rem;
  }

  .site-footer__newsletter-field {
    display: flex;
    border-bottom: 1px solid var(--color-border);
  }

  .site-footer__newsletter-input {
    flex: 1;
    background: transparent;
    border: none;
    color: var(--color-foreground);
    font-family: inherit;
    font-size: 14px;
    padding: 0.625rem 0;
    outline: none;
  }

  .site-footer__newsletter-input::placeholder {
    color: #5c564c;
  }

  .site-footer__newsletter-submit {
    background: none;
    border: none;
    color: var(--color-gold);
    font-size: 18px;
    cursor: pointer;
    padding: 0 0.25rem;
  }

  .site-footer__newsletter-success {
    color: var(--color-gold);
    font-size: 13px;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .site-footer__bottom {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    border-top: 1px solid var(--color-border);
    padding: 1.75rem 0;
  }

  .site-footer__wordmark {
    font-family: var(--font-heading--family);
    font-size: 32px;
    letter-spacing: 0.04em;
    color: var(--color-gold);
    line-height: 1;
  }

  .site-footer__meta {
    color: #5c564c;
    font-size: 12px;
    text-align: right;
  }

  .site-footer__copyright {
    margin-top: 0.5rem;
    max-width: 320px;
  }

  @media (max-width: 900px) {
    .site-footer__grid,
    .site-footer__columns {
      grid-template-columns: 1fr;
    }

    .site-footer__image {
      display: none;
    }

    .site-footer__bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }

    .site-footer__meta {
      text-align: left;
    }

    .site-footer__watermark {
      width: 260px;
      height: 260px;
      bottom: -80px;
      right: -60px;
    }
  }

  @media (max-width: 700px) {
    .site-footer__inner {
      padding: 0 1.5rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "lifestyle_image",
      "label": "t:labels.lifestyle_image"
    },
    {
      "type": "link_list",
      "id": "pages_menu",
      "label": "t:labels.pages_menu",
      "default": "footer"
    },
    {
      "type": "link_list",
      "id": "support_menu",
      "label": "t:labels.support_menu"
    },
    {
      "type": "text",
      "id": "wordmark_text",
      "label": "t:labels.wordmark_text",
      "default": "SAINT SAMSON"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "t:labels.tagline",
      "default": "Fragrance Oils · Paris"
    },
    {
      "type": "richtext",
      "id": "copyright_text",
      "label": "t:labels.copyright_text",
      "default": "<p>© 2026 Saint Samson Paris. All fragrances are inspired-by interpretations, independently blended and not affiliated with the original houses.</p>"
    },
    {
      "type": "text",
      "id": "contact_email",
      "label": "t:labels.email",
      "default": "hello@saintsamsonparis.example"
    },
    {
      "type": "text",
      "id": "contact_address",
      "label": "t:labels.address",
      "default": "5614 W Grand Parkway S Ste 102, Richmond, TX 77406, United States"
    }
  ]
}
{% endschema %}
