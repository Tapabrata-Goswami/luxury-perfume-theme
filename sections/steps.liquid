<div class="steps">
  <div class="steps__header">
    {%- if section.settings.eyebrow != blank -%}
      <div class="steps__eyebrow">{{ section.settings.eyebrow }}</div>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="steps__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
  </div>

  <div class="steps__grid">
    <div class="steps__line"></div>
    {%- for block in section.blocks -%}
      {% render block %}
    {%- endfor -%}
  </div>
</div>

{% stylesheet %}
  .steps {
    padding: 6.25rem 4rem;
    background: var(--color-background);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .steps__header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .steps__eyebrow {
    color: var(--color-gold);
    font-size: 13px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .steps__heading {
    font-family: var(--font-heading--family);
    font-weight: 500;
    font-size: 36px;
    margin: 0;
  }

  .steps__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    max-width: 1000px;
    margin: 0 auto;
    position: relative;
  }

  .steps__line {
    position: absolute;
    top: 26px;
    left: 16.6%;
    right: 16.6%;
    height: 1px;
    background: rgba(196, 161, 90, 0.3);
  }

  @media (max-width: 700px) {
    .steps {
      padding-left: 0;
      padding-right: 0;
    }

    .steps__grid {
      grid-template-columns: 1fr;
      gap: 1.75rem;
    }

    .steps__line {
      display: none;
    }

    .steps__grid > *:nth-child(n + 3) {
      padding-top: 1.75rem;
      border-top: 1px solid var(--color-border);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.steps",
  "blocks": [
    {
      "type": "step"
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow",
      "default": "The Ritual"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "How to Wear It"
    }
  ],
  "presets": [
    {
      "name": "t:general.steps",
      "blocks": [
        { "type": "step", "settings": { "icon": "droplet", "number": "01", "title": "Apply to Pulse Points", "body": "Wrists, neck, behind the ears, and inner elbows — warmth helps the oil bloom." } },
        { "type": "step", "settings": { "icon": "hourglass", "number": "02", "title": "Let It Develop", "body": "Give the oil a few minutes to settle into skin before layering scents." } },
        { "type": "step", "settings": { "icon": "refresh", "number": "03", "title": "Refresh Throughout the Day", "body": "Oils wear close to skin — a light reapplication midday keeps it alive." } }
      ]
    }
  ]
}
{% endschema %}
