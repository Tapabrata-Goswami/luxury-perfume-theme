<div class="bestsellers-spotlight">
  {%- if section.settings.heading != blank -%}
    <h2 class="bestsellers-spotlight__heading">{{ section.settings.heading }}</h2>
  {%- endif -%}
  <div class="bestsellers-spotlight__grid">
    {% content_for 'blocks' %}
  </div>
</div>

{% stylesheet %}
  .bestsellers-spotlight {
    padding: 5.625rem 0;
    border-top: 1px solid var(--color-border);
  }

  .bestsellers-spotlight__heading {
    font-family: var(--font-heading--family);
    font-weight: 500;
    font-size: 36px;
    text-align: center;
    margin: 0 0 3rem;
  }

  .bestsellers-spotlight__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.5rem;
  }

  @media (max-width: 700px) {
    .bestsellers-spotlight__heading {
      font-size: 28px;
    }

    .bestsellers-spotlight__grid {
      grid-template-columns: 1fr;
      gap: 2.75rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.bestsellers_spotlight",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Our Best Selling Perfume Oils"
    }
  ],
  "blocks": [
    {
      "type": "spotlight-product"
    }
  ],
  "presets": [
    {
      "name": "t:general.bestsellers_spotlight",
      "blocks": [
        { "type": "spotlight-product", "settings": { "body": "Blush Royale is our most-gifted fragrance oil — a soft floral musk inspired by Chloé Nomade, perfect for everyday luxury and thoughtful gifting." } },
        { "type": "spotlight-product", "settings": { "body": "Velvet Cherry is a rich, gourmand fragrance oil inspired by Tom Ford Lost Cherry — bold cherry liqueur and almond wrapped in warm, sensual musk." } },
        { "type": "spotlight-product", "settings": { "body": "Red Alchemy is our top-selling unisex fragrance oil, inspired by Baccarat Rouge 540 — saffron, ambergris and cedarwood in a long-lasting amber base." } }
      ]
    }
  ]
}
{% endschema %}
