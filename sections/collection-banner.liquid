<div class="collection-banner">
  <nav class="collection-banner__breadcrumb" aria-label="breadcrumb">
    <a href="{{ routes.root_url }}">{{ 'general.maison' | t }}</a>
    <span aria-hidden="true">/</span>
    <a href="{{ routes.collections_url }}">{{ 'general.collections' | t }}</a>
    <span aria-hidden="true">/</span>
    <span aria-current="page">{{ section.settings.heading | default: collection.title }}</span>
  </nav>
</div>

{% stylesheet %}
  .collection-banner {
    padding: 2rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .collection-banner__breadcrumb {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    color: var(--color-gold);
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .collection-banner__breadcrumb a {
    color: var(--color-gold);
    text-decoration: none;
  }

  .collection-banner__breadcrumb a:hover {
    text-decoration: underline;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.collection_banner",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Our Signature Fragrances"
    }
  ],
  "presets": [
    {
      "name": "t:general.collection_banner"
    }
  ]
}
{% endschema %}
