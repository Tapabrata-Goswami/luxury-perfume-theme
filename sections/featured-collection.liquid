<div class="featured-collection">
  <div class="featured-collection__header">
    {%- if section.settings.heading != blank -%}
      <h2 class="featured-collection__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="featured-collection__controls">
      {%- if section.settings.collection != blank -%}
        <a
          href="{{ section.settings.view_all_link | default: section.settings.collection.url }}"
          class="featured-collection__view-all"
        >
          {{- section.settings.view_all_text }} &rarr;
        </a>
      {%- endif -%}
      <div class="featured-collection__arrows">
        <button type="button" class="featured-collection__arrow featured-collection__arrow--prev" aria-label="{{ 'general.previous' | t }}">&larr;</button>
        <button type="button" class="featured-collection__arrow featured-collection__arrow--next" aria-label="{{ 'general.next' | t }}">&rarr;</button>
      </div>
    </div>
  </div>

  <div class="featured-collection__viewport">
    <div class="featured-collection__track">
      {%- if section.settings.collection != blank -%}
        {%- for product in section.settings.collection.products limit: section.settings.product_limit -%}
          <a href="{{ product.url }}" class="featured-collection__card">
            <div class="featured-collection__card-image">
              {%- if product.compare_at_price > product.price -%}
                {%- assign discount_percent = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
                <span class="featured-collection__card-badge">-{{ discount_percent }}%</span>
              {%- endif -%}
              {%- if product.featured_image != blank -%}
                {{ product.featured_image | image_url: width: 600 | image_tag: sizes: '300px', class: 'featured-collection__card-img featured-collection__card-img--primary', alt: product.featured_image.alt | default: product.title }}
              {%- endif -%}
              {%- if product.images.size > 1 -%}
                {{ product.images[1] | image_url: width: 600 | image_tag: sizes: '300px', class: 'featured-collection__card-img featured-collection__card-img--secondary', alt: '' }}
              {%- endif -%}
            </div>
            {%- if product.metafields.custom.inspired_by != blank -%}
              <div class="featured-collection__card-inspired">{{ 'product.inspired_by_html' | t: name: product.metafields.custom.inspired_by }}</div>
            {%- endif -%}
            <div class="featured-collection__card-title">{{ product.title }}</div>
            {%- if product.metafields.custom.fragrance_family != blank -%}
              <div class="featured-collection__card-family">{{ product.metafields.custom.fragrance_family.value | split: ',' | join: ' · ' }}</div>
            {%- endif -%}
            <div class="featured-collection__card-price">
              {%- if product.compare_at_price > product.price -%}
                <span class="featured-collection__card-price-compare">{{ product.compare_at_price | money }}</span>
              {%- endif -%}
              <span class="featured-collection__card-price-current">{{ product.price | money }}</span>
              {%- assign variant_title = product.selected_or_first_available_variant.title -%}
              {%- if variant_title != blank and variant_title != 'Default Title' -%}
                &middot; {{ variant_title }}
              {%- endif -%}
            </div>
          </a>
        {%- endfor -%}
      {%- elsif request.design_mode -%}
        <p class="featured-collection__empty">{{ 'product.no_collection_selected' | t }}</p>
      {%- endif -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .featured-collection {
    padding: 5.625rem 0 3.75rem;
  }

  .featured-collection__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 3rem;
  }

  .featured-collection__heading {
    font-family: var(--font-heading--family);
    font-weight: 500;
    font-size: 36px;
    margin: 0;
  }

  .featured-collection__controls {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .featured-collection__view-all {
    color: var(--color-gold);
    text-decoration: none;
    font-size: 13px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .featured-collection__arrows {
    display: flex;
    gap: 0.625rem;
  }

  .featured-collection__arrow {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    cursor: pointer;
    font-size: 16px;
    font-family: inherit;
  }

  .featured-collection__arrow--prev {
    background: transparent;
    border: 1px solid var(--color-gold-dark);
    color: var(--color-gold-dark);
  }

  .featured-collection__arrow--next {
    background: var(--color-gold-dark);
    border: none;
    color: var(--color-background);
  }

  .featured-collection__arrow:disabled {
    opacity: 0.35;
    cursor: default;
  }

  .featured-collection__viewport {
    overflow: hidden;
    touch-action: pan-y;
  }

  .featured-collection__track {
    display: flex;
    gap: 2rem;
    transition: transform 0.5s ease;
  }

  .featured-collection__card {
    text-decoration: none;
    color: inherit;
    display: block;
    flex: 0 0 300px;
    transition: transform 0.35s ease;
  }

  .featured-collection__card:hover {
    transform: translateY(-6px);
  }

  .featured-collection__card-image {
    position: relative;
    aspect-ratio: 1 / 1.1;
    overflow: hidden;
    margin-bottom: 1.125rem;
    background: var(--color-surface);
    border-radius: 4px;
  }

  .featured-collection__card-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.5s ease, transform 0.6s ease;
  }

  .featured-collection__card:hover .featured-collection__card-img {
    transform: scale(1.06);
  }

  .featured-collection__card-img--secondary {
    opacity: 0;
  }

  .featured-collection__card:hover .featured-collection__card-img--primary:has(+ .featured-collection__card-img--secondary) {
    opacity: 0;
  }

  .featured-collection__card:hover .featured-collection__card-img--secondary {
    opacity: 1;
  }

  .featured-collection__card-badge {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    z-index: 2;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    background: var(--color-gold-dark);
    color: var(--color-background);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .featured-collection__card-inspired {
    color: var(--color-muted);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 0.375rem;
  }

  .featured-collection__card-title {
    font-size: 19px;
    font-family: var(--font-heading--family);
    margin-bottom: 0.375rem;
    transition: color 0.25s ease;
  }

  .featured-collection__card:hover .featured-collection__card-title {
    color: var(--color-gold);
  }

  .featured-collection__card-family {
    color: var(--color-muted);
    font-size: 12px;
    margin-bottom: 0.375rem;
  }

  .featured-collection__card-price {
    color: var(--color-gold);
    font-size: 14px;
  }

  .featured-collection__card-price-compare {
    color: var(--color-muted);
    text-decoration: line-through;
    margin-right: 0.5rem;
  }

  .featured-collection__empty {
    color: var(--color-muted);
    font-size: 14px;
  }

  @media (max-width: 700px) {
    .featured-collection {
      padding: 2.75rem 0 2rem;
    }

    .featured-collection__header {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
      margin-bottom: 1.75rem;
    }

    .featured-collection__heading {
      font-size: 28px;
    }

    .featured-collection__card {
      flex: 0 0 78vw;
    }
  }
{% endstylesheet %}

{% javascript %}
  document.querySelectorAll('.featured-collection').forEach((root) => {
    const viewport = root.querySelector('.featured-collection__viewport');
    const track = root.querySelector('.featured-collection__track');
    const prevButton = root.querySelector('.featured-collection__arrow--prev');
    const nextButton = root.querySelector('.featured-collection__arrow--next');
    const cards = Array.from(track.children);

    if (!cards.length) return;

    let slide = 0;

    function getStep() {
      const style = getComputedStyle(track);
      return cards[0].getBoundingClientRect().width + parseFloat(style.gap || 0);
    }

    function getVisibleCount() {
      const step = getStep();
      return Math.max(1, Math.round(viewport.getBoundingClientRect().width / step));
    }

    function update() {
      const maxSlide = Math.max(0, cards.length - getVisibleCount());
      slide = Math.min(slide, maxSlide);
      track.style.transform = 'translateX(-' + slide * getStep() + 'px)';
      if (prevButton) prevButton.disabled = slide <= 0;
      if (nextButton) nextButton.disabled = slide >= maxSlide;
    }

    if (prevButton) {
      prevButton.addEventListener('click', () => {
        slide = Math.max(0, slide - 1);
        update();
      });
    }

    if (nextButton) {
      nextButton.addEventListener('click', () => {
        const maxSlide = Math.max(0, cards.length - getVisibleCount());
        slide = Math.min(maxSlide, slide + 1);
        update();
      });
    }

    let isDragging = false;
    let dragStartX = 0;
    let dragStartTranslate = 0;
    let hasDragged = false;

    viewport.addEventListener('pointerdown', (e) => {
      if (e.pointerType === 'mouse' && e.button !== 0) return;
      isDragging = true;
      hasDragged = false;
      dragStartX = e.clientX;
      dragStartTranslate = slide * getStep();
      track.style.transition = 'none';
      viewport.setPointerCapture(e.pointerId);
    });

    viewport.addEventListener('pointermove', (e) => {
      if (!isDragging) return;
      const delta = e.clientX - dragStartX;
      if (Math.abs(delta) > 6) hasDragged = true;
      track.style.transform = 'translateX(-' + (dragStartTranslate - delta) + 'px)';
    });

    function endDrag(e) {
      if (!isDragging) return;
      isDragging = false;
      track.style.transition = '';

      const delta = e.clientX - dragStartX;
      const step = getStep();
      const maxSlide = Math.max(0, cards.length - getVisibleCount());

      if (Math.abs(delta) > step * 0.2) {
        slide = delta < 0 ? Math.min(maxSlide, slide + 1) : Math.max(0, slide - 1);
      }

      update();
    }

    viewport.addEventListener('pointerup', endDrag);
    viewport.addEventListener('pointercancel', endDrag);

    track.addEventListener('click', (e) => {
      if (hasDragged) {
        e.preventDefault();
        hasDragged = false;
      }
    });

    window.addEventListener('resize', update);
    update();
  });
{% endjavascript %}

{% schema %}
{
  "name": "t:general.featured_collection",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "The Collection"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "t:labels.collection"
    },
    {
      "type": "range",
      "id": "product_limit",
      "label": "t:labels.product_limit",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 5
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "t:labels.view_all_text",
      "default": "View All"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "t:labels.view_all_link"
    }
  ],
  "presets": [
    {
      "name": "t:general.featured_collection"
    }
  ]
}
{% endschema %}
