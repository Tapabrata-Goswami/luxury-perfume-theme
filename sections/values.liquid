<div class="values">
  {%- if section.settings.eyebrow != blank -%}
    <div class="values__eyebrow">{{ section.settings.eyebrow }}</div>
  {%- endif -%}
  {%- if section.settings.heading != blank -%}
    <h2 class="values__heading">{{ section.settings.heading }}</h2>
  {%- endif -%}
  <div class="values__grid">
    {% content_for 'blocks' %}
  </div>
</div>

{% stylesheet %}
  .values {
    padding: 5.625rem 0;
    border-top: 1px solid var(--color-border);
  }

  .values__eyebrow {
    color: var(--color-gold);
    font-size: 13px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    text-align: center;
    margin-bottom: 1.25rem;
  }

  .values__heading {
    font-family: var(--font-heading--family);
    font-weight: 500;
    font-size: 36px;
    text-align: center;
    margin: 0 0 3rem;
  }

  .values__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  @media (max-width: 700px) {
    .values__grid {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.values",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow",
      "default": "What We Stand For"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Our Values"
    }
  ],
  "blocks": [
    {
      "type": "value"
    }
  ],
  "presets": [
    {
      "name": "t:general.values",
      "blocks": [
        { "type": "value", "settings": { "number": "01", "title": "No Shortcuts", "body": "Every ingredient is sourced directly, never through a fragrance house's stock blends." } },
        { "type": "value", "settings": { "number": "02", "title": "Small Batches", "body": "No batch exceeds 200 bottles. When it's gone, it's gone until the next run." } },
        { "type": "value", "settings": { "number": "03", "title": "One Signature", "body": "We'd rather perfect nine scents than release ninety mediocre ones." } }
      ]
    }
  ]
}
{% endschema %}
