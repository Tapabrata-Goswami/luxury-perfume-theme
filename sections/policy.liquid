<div class="policy-page">
  <div class="policy-page__breadcrumb">
    <a href="{{ routes.root_url }}">{{ 'general.maison' | t }}</a>
    &#47;
    <span>{{ policy.title }}</span>
  </div>

  <h1 class="policy-page__title">{{ policy.title }}</h1>

  <div class="policy-page__body">
    {{ policy.body }}
  </div>
</div>

{% stylesheet %}
  .policy-page {
    padding: 3rem 4rem 8rem;
    max-width: 760px;
    margin: 0 auto;
  }

  .policy-page__breadcrumb {
    color: var(--color-muted);
    font-size: 13px;
    margin-bottom: 1.5rem;
  }

  .policy-page__breadcrumb a {
    color: var(--color-muted);
    text-decoration: none;
  }

  .policy-page__breadcrumb span {
    color: #e5dccb;
  }

  .policy-page__title {
    font-family: var(--font-heading--family);
    font-weight: 500;
    font-size: 42px;
    margin: 0 0 2.5rem;
  }

  .policy-page__body {
    color: var(--color-secondary-text);
    font-size: 16px;
    line-height: 1.8;
  }

  .policy-page__body h1,
  .policy-page__body h2,
  .policy-page__body h3 {
    font-family: var(--font-heading--family);
    color: var(--color-foreground);
    font-weight: 500;
    margin: 2rem 0 1rem;
  }

  .policy-page__body h2 {
    font-size: 26px;
  }

  .policy-page__body h3 {
    font-size: 20px;
  }

  .policy-page__body p {
    margin: 0 0 1.25rem;
  }

  .policy-page__body a {
    color: var(--color-gold);
  }

  .policy-page__body ul,
  .policy-page__body ol {
    margin: 0 0 1.25rem;
    padding-left: 1.5rem;
  }

  .policy-page__body li {
    margin-bottom: 0.5rem;
  }

  @media (max-width: 700px) {
    .policy-page {
      padding: 2.5rem 0 5rem;
    }

    .policy-page__title {
      font-size: 32px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.policy",
  "settings": []
}
{% endschema %}
