<div class="cta-banner">
  {%- if section.settings.heading != blank -%}
    <h2 class="cta-banner__heading">{{ section.settings.heading }}</h2>
  {%- endif -%}
  {%- if section.settings.button_text != blank -%}
    <a href="{{ section.settings.button_link | default: '#' }}" class="cta-banner__button">
      {{- section.settings.button_text -}}
    </a>
  {%- endif -%}
</div>

{% stylesheet %}
  .cta-banner {
    padding: 5rem 0;
    text-align: center;
  }

  .cta-banner__heading {
    font-family: var(--font-heading--family);
    font-weight: 500;
    font-size: 36px;
    margin: 0 0 1.875rem;
  }

  .cta-banner__button {
    display: inline-block;
    background: var(--color-gold-dark);
    color: var(--color-background);
    text-decoration: none;
    padding: 1.125rem 2.75rem;
    font-size: 13px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border-radius: 4px;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.cta_banner",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Experience it for yourself."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "t:labels.button_text",
      "default": "Shop the Collection"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "t:labels.button_link",
      "default": "/collections/all"
    }
  ],
  "presets": [
    {
      "name": "t:general.cta_banner"
    }
  ]
}
{% endschema %}
