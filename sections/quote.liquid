<div class="quote-section full-width">
  <div class="quote-section__inner">
    <div class="quote-section__photo">
      {%- if section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 280 | image_tag: sizes: '140px', class: 'quote-section__img', alt: '' }}
      {%- else -%}
        <div class="quote-section__placeholder">{{ section.settings.placeholder_label }}</div>
      {%- endif -%}
    </div>

    <div class="quote-section__content">
      {%- if section.settings.quote != blank -%}
        <p class="quote-section__quote">&ldquo;{{ section.settings.quote }}&rdquo;</p>
      {%- endif -%}
      {%- if section.settings.attribution != blank -%}
        <div class="quote-section__attribution">{{ section.settings.attribution }}</div>
      {%- endif -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .quote-section {
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .quote-section__inner {
    padding: 6.875rem 4rem;
    max-width: var(--page-width);
    margin-inline: auto;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 3.125rem;
    align-items: center;
  }

  .quote-section__photo,
  .quote-section__placeholder {
    width: 140px;
    height: 140px;
    border-radius: 50%;
    overflow: hidden;
  }

  .quote-section__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .quote-section__placeholder {
    background: repeating-linear-gradient(135deg, #1a1713, #1a1713 10px, #221e18 10px, #221e18 20px);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-muted);
    font-family: ui-monospace, monospace;
    font-size: 9px;
    text-align: center;
    padding: 1rem;
  }

  .quote-section__quote {
    font-family: var(--font-heading--family);
    font-style: italic;
    font-size: 26px;
    line-height: 1.6;
    margin: 0 0 1rem;
    color: var(--color-foreground);
  }

  .quote-section__attribution {
    color: var(--color-muted);
    font-size: 14px;
    letter-spacing: 0.05em;
  }

  @media (max-width: 700px) {
    .quote-section__inner {
      grid-template-columns: 1fr;
      text-align: center;
      justify-items: center;
      padding: 4rem 1.5rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.quote_section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:labels.image"
    },
    {
      "type": "text",
      "id": "placeholder_label",
      "label": "t:labels.placeholder_label",
      "default": "Founder photo"
    },
    {
      "type": "textarea",
      "id": "quote",
      "label": "t:labels.quote",
      "default": "A scent should make people ask what you're wearing — not remind them of something they already own."
    },
    {
      "type": "text",
      "id": "attribution",
      "label": "t:labels.attribution",
      "default": "Founder & Perfumer, Saint Samson"
    }
  ],
  "presets": [
    {
      "name": "t:general.quote_section"
    }
  ]
}
{% endschema %}
