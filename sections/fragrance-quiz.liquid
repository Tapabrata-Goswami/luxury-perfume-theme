{%- assign question_blocks = section.blocks | where: 'type', 'question' -%}
{%- assign quiz_products = section.settings.collection.products -%}

<div
  id="fragrance-quiz-section"
  class="fragrance-quiz"
  data-fragrance-quiz
  data-step-label="{{ 'quiz.step_label' | t }}"
  data-shop-label="{{ 'quiz.shop_this_scent' | t }}"
  data-no-match-label="{{ 'quiz.no_match' | t }}"
  data-browse-label="{{ 'quiz.browse_all' | t }}"
  data-all-url="{{ section.settings.collection.url | default: routes.all_products_collection_url }}"
>
  <div class="fragrance-quiz__intro" data-quiz-intro>
    {%- if section.settings.eyebrow != blank -%}
      <div class="fragrance-quiz__eyebrow">{{ section.settings.eyebrow }}</div>
    {%- endif -%}
    <h2 class="fragrance-quiz__heading">{{ section.settings.heading }}</h2>
    {%- if section.settings.subheading != blank -%}
      <p class="fragrance-quiz__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}

    {%- if question_blocks.size > 0 and quiz_products.size > 0 -%}
      <button type="button" class="fragrance-quiz__start" data-quiz-start>{{ 'quiz.start' | t }}</button>
    {%- elsif request.design_mode -%}
      <p class="fragrance-quiz__empty">Add question blocks and select a products collection in the section settings to activate the quiz.</p>
    {%- endif -%}
  </div>

  {%- if question_blocks.size > 0 -%}
    <div class="fragrance-quiz__questions" data-quiz-questions hidden>
      <div class="fragrance-quiz__progress">
        <div class="fragrance-quiz__progress-bar">
          <div class="fragrance-quiz__progress-fill" data-quiz-progress-fill></div>
        </div>
        <div class="fragrance-quiz__progress-label" data-quiz-progress-label></div>
      </div>

      {%- for block in question_blocks -%}
        <div
          class="fragrance-quiz__question"
          data-quiz-question
          data-index="{{ forloop.index0 }}"
          {% unless forloop.first %}hidden{% endunless %}
          {{ block.shopify_attributes }}
        >
          <div class="fragrance-quiz__question-text">{{ block.settings.question }}</div>
          <div class="fragrance-quiz__options">
            {%- for i in (1..4) -%}
              {%- assign label_key = 'option_' | append: i | append: '_label' -%}
              {%- assign tag_key = 'option_' | append: i | append: '_tag' -%}
              {%- assign option_label = block.settings[label_key] -%}
              {%- assign option_tag = block.settings[tag_key] -%}
              {%- if option_label != blank -%}
                <button type="button" class="fragrance-quiz__option" data-quiz-option data-tag="{{ option_tag | escape }}">
                  {{- option_label -}}
                </button>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  {%- endif -%}

  <div class="fragrance-quiz__result" data-quiz-result hidden>
    <div class="fragrance-quiz__confetti" data-quiz-confetti aria-hidden="true"></div>
    <div class="fragrance-quiz__result-eyebrow">{{ section.settings.result_heading }}</div>
    <div class="fragrance-quiz__result-card" data-quiz-result-card></div>
    <button type="button" class="fragrance-quiz__retake" data-quiz-retake>{{ 'quiz.retake' | t }}</button>
  </div>

  <script type="application/json" data-quiz-products>
    [
      {%- for product in quiz_products limit: 24 -%}
        {%- assign family_raw = product.metafields.custom.fragrance_family.value | default: '' -%}
        {
          "id": {{ product.id | json }},
          "title": {{ product.title | json }},
          "url": {{ product.url | json }},
          "image": {{ product.featured_image | image_url: width: 600 | json }},
          "price": {{ product.price | json }},
          "compareAtPrice": {{ product.compare_at_price | json }},
          "tags": {{ product.tags | json }},
          "family": {{ family_raw | split: ',' | json }},
          "tagline": {{ product.metafields.custom.tagline | default: '' | json }}
        }{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    ]
  </script>
</div>

{% stylesheet %}
  .fragrance-quiz {
    padding: 5.625rem 4rem;
    background:
      radial-gradient(ellipse at top, color-mix(in srgb, var(--color-gold) 14%, transparent), transparent 60%),
      var(--color-surface-dark);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .fragrance-quiz__intro {
    max-width: 560px;
    margin: 0 auto;
    text-align: center;
  }

  .fragrance-quiz__eyebrow {
    color: var(--color-gold);
    font-size: 13px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    margin-bottom: 1.25rem;
  }

  .fragrance-quiz__heading {
    font-family: var(--font-heading--family);
    font-weight: 500;
    font-size: 36px;
    margin: 0 0 1rem;
  }

  .fragrance-quiz__subheading {
    color: var(--color-secondary-text);
    font-size: 15px;
    line-height: 1.7;
    margin: 0 0 2rem;
  }

  .fragrance-quiz__empty {
    color: var(--color-muted);
    font-size: 13px;
  }

  .fragrance-quiz__start,
  .fragrance-quiz__retake {
    display: inline-block;
    background: var(--color-gold-dark);
    color: var(--color-background);
    border: none;
    padding: 1.125rem 2.75rem;
    font-size: 13px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
  }

  .fragrance-quiz__questions {
    max-width: 560px;
    margin: 3rem auto 0;
  }

  .fragrance-quiz__progress {
    margin-bottom: 2.5rem;
  }

  .fragrance-quiz__progress-bar {
    height: 2px;
    background: var(--color-border);
    margin-bottom: 0.75rem;
  }

  .fragrance-quiz__progress-fill {
    height: 100%;
    width: 0%;
    background: var(--color-gold);
    transition: width 0.35s ease;
  }

  .fragrance-quiz__progress-label {
    color: var(--color-muted);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-align: center;
  }

  .fragrance-quiz__question-text {
    font-family: var(--font-heading--family);
    font-weight: 500;
    font-size: 24px;
    text-align: center;
    margin-bottom: 2rem;
  }

  .fragrance-quiz__options {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .fragrance-quiz__option {
    background: var(--color-background);
    border: 1px solid var(--color-border);
    color: var(--color-foreground);
    padding: 1.25rem 1rem;
    font-size: 14px;
    font-family: inherit;
    text-align: center;
    cursor: pointer;
    transition: border-color 0.2s ease, color 0.2s ease, background-color 0.2s ease;
  }

  .fragrance-quiz__option:hover {
    border-color: var(--color-gold);
    color: var(--color-gold);
  }

  .fragrance-quiz__result {
    position: relative;
    max-width: 640px;
    margin: 3rem auto 0;
    text-align: center;
  }

  .fragrance-quiz__confetti {
    position: absolute;
    top: -1.5rem;
    left: 0;
    right: 0;
    height: 0;
    overflow: visible;
    pointer-events: none;
    z-index: 5;
  }

  .fragrance-quiz__confetti-piece {
    position: absolute;
    top: 0;
    left: var(--confetti-left);
    width: var(--confetti-size);
    height: calc(var(--confetti-size) * 1.8);
    background: var(--confetti-color);
    opacity: 0;
    border-radius: 1px;
    animation: fragrance-quiz-confetti-fall var(--confetti-duration) ease-out forwards;
    animation-delay: var(--confetti-delay);
  }

  @keyframes fragrance-quiz-confetti-fall {
    0% {
      opacity: 1;
      transform: translate(0, 0) rotate(0deg);
    }
    100% {
      opacity: 0;
      transform: translate(var(--confetti-drift), 220px) rotate(var(--confetti-rotate));
    }
  }

  .fragrance-quiz__result-eyebrow {
    color: var(--color-gold);
    font-size: 13px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }

  .fragrance-quiz__result-card {
    display: flex;
    align-items: center;
    gap: 2rem;
    text-align: left;
    background: var(--color-background);
    border: 1px solid var(--color-border);
    padding: 2rem;
    margin-bottom: 2rem;
  }

  .fragrance-quiz__result-image {
    display: block;
    flex: 0 0 160px;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: var(--color-surface);
    border-radius: 4px;
  }

  .fragrance-quiz__result-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .fragrance-quiz__result-info {
    min-width: 0;
  }

  .fragrance-quiz__result-title {
    font-family: var(--font-heading--family);
    font-weight: 500;
    font-size: 26px;
    margin: 0 0 0.5rem;
  }

  .fragrance-quiz__result-tagline {
    color: var(--color-secondary-text);
    font-size: 14px;
    font-style: italic;
    font-family: var(--font-heading--family);
    margin: 0 0 1rem;
  }

  .fragrance-quiz__result-price {
    color: var(--color-gold);
    font-size: 18px;
    margin-bottom: 1.25rem;
  }

  .fragrance-quiz__result-price-compare {
    color: var(--color-muted);
    text-decoration: line-through;
    font-size: 14px;
    margin-right: 0.5rem;
  }

  .fragrance-quiz__result-button {
    display: inline-block;
    background: var(--color-gold-dark);
    color: var(--color-background);
    text-decoration: none;
    padding: 0.875rem 1.75rem;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .fragrance-quiz__result-empty {
    color: var(--color-muted);
    font-size: 14px;
    margin-bottom: 1.5rem;
  }

  @media (max-width: 700px) {
    .fragrance-quiz {
      padding: 4rem 1rem;
    }

    .fragrance-quiz__heading {
      font-size: 28px;
    }

    .fragrance-quiz__options {
      grid-template-columns: 1fr;
    }

    .fragrance-quiz__result-card {
      flex-direction: column;
      text-align: center;
    }

    .fragrance-quiz__result-image {
      flex: 0 0 auto;
      width: 160px;
    }
  }
{% endstylesheet %}

{% javascript %}
  document.querySelectorAll('[data-fragrance-quiz]').forEach((root) => {
    const startPanel = root.querySelector('[data-quiz-intro]');
    const questionsPanel = root.querySelector('[data-quiz-questions]');
    const resultPanel = root.querySelector('[data-quiz-result]');
    const startButton = root.querySelector('[data-quiz-start]');
    const retakeButton = root.querySelector('[data-quiz-retake]');
    const questions = Array.from(root.querySelectorAll('[data-quiz-question]'));
    const progressFill = root.querySelector('[data-quiz-progress-fill]');
    const progressLabel = root.querySelector('[data-quiz-progress-label]');
    const resultCard = root.querySelector('[data-quiz-result-card]');
    const confettiContainer = root.querySelector('[data-quiz-confetti]');
    const dataScript = root.querySelector('[data-quiz-products]');

    if (!startButton || !questions.length) return;

    const stepLabelTemplate = root.getAttribute('data-step-label') || 'Step {current} of {total}';
    const shopLabel = root.getAttribute('data-shop-label') || 'Shop This Scent';
    const noMatchLabel = root.getAttribute('data-no-match-label') || "We couldn't find a match.";
    const browseLabel = root.getAttribute('data-browse-label') || 'Browse All';
    const allUrl = root.getAttribute('data-all-url') || '/collections/all';

    let products = [];
    try {
      products = dataScript ? JSON.parse(dataScript.textContent) : [];
    } catch (e) {
      products = [];
    }

    let answers = [];
    let currentIndex = 0;

    function escapeHtml(value) {
      const div = document.createElement('div');
      div.textContent = value == null ? '' : String(value);
      return div.innerHTML;
    }

    function formatMoney(cents) {
      return '$' + (cents / 100).toFixed(2);
    }

    function updateProgress() {
      const percent = Math.round(((currentIndex + 1) / questions.length) * 100);
      if (progressFill) progressFill.style.width = percent + '%';
      if (progressLabel) {
        progressLabel.textContent = stepLabelTemplate
          .replace('{current}', currentIndex + 1)
          .replace('{total}', questions.length);
      }
    }

    function showQuestion(index) {
      questions.forEach((question, i) => {
        question.hidden = i !== index;
      });
      updateProgress();
    }

    function spawnConfetti() {
      if (!confettiContainer) return;

      confettiContainer.innerHTML = '';

      const rootStyles = getComputedStyle(document.documentElement);
      const colors = [
        (rootStyles.getPropertyValue('--color-gold') || '#c9a24a').trim(),
        (rootStyles.getPropertyValue('--color-gold-dark') || '#b8860b').trim(),
        '#e5dccb',
        '#8a7f6b',
      ];

      for (let i = 0; i < 28; i += 1) {
        const piece = document.createElement('span');
        piece.className = 'fragrance-quiz__confetti-piece';
        piece.style.setProperty('--confetti-left', (Math.random() * 100) + '%');
        piece.style.setProperty('--confetti-size', (4 + Math.random() * 4) + 'px');
        piece.style.setProperty('--confetti-color', colors[Math.floor(Math.random() * colors.length)]);
        piece.style.setProperty('--confetti-drift', (Math.random() * 120 - 60) + 'px');
        piece.style.setProperty('--confetti-rotate', (Math.random() * 540 - 270) + 'deg');
        piece.style.setProperty('--confetti-duration', (0.9 + Math.random() * 0.6) + 's');
        piece.style.setProperty('--confetti-delay', (Math.random() * 0.25) + 's');
        confettiContainer.appendChild(piece);
      }

      window.setTimeout(() => {
        confettiContainer.innerHTML = '';
      }, 1800);
    }

    function computeMatch() {
      if (!products.length) return null;

      const scored = products.map((product) => {
        const keywords = []
          .concat((product.tags || []).map((tag) => tag.toLowerCase().trim()))
          .concat((product.family || []).map((tag) => tag.toLowerCase().trim()));

        const score = answers.reduce((total, tag) => {
          if (!tag) return total;
          return keywords.indexOf(tag.toLowerCase().trim()) !== -1 ? total + 1 : total;
        }, 0);

        return { product, score };
      });

      scored.sort((a, b) => b.score - a.score);
      return scored[0];
    }

    function renderResult() {
      const match = computeMatch();

      if (!match || match.score === 0) {
        resultCard.innerHTML =
          '<div class="fragrance-quiz__result-empty">' + escapeHtml(noMatchLabel) + '</div>' +
          '<a href="' + escapeHtml(allUrl) + '" class="fragrance-quiz__result-button">' + escapeHtml(browseLabel) + '</a>';
        questionsPanel.hidden = true;
        resultPanel.hidden = false;
        return;
      }

      const product = match.product;
      const priceMarkup = product.compareAtPrice && product.compareAtPrice > product.price
        ? '<span class="fragrance-quiz__result-price-compare">' + formatMoney(product.compareAtPrice) + '</span><span>' + formatMoney(product.price) + '</span>'
        : '<span>' + formatMoney(product.price) + '</span>';

      resultCard.innerHTML =
        '<a href="' + escapeHtml(product.url) + '" class="fragrance-quiz__result-image">' +
          (product.image ? '<img src="' + escapeHtml(product.image) + '" alt="' + escapeHtml(product.title) + '" width="160" height="160" loading="lazy">' : '') +
        '</a>' +
        '<div class="fragrance-quiz__result-info">' +
          '<h3 class="fragrance-quiz__result-title">' + escapeHtml(product.title) + '</h3>' +
          (product.tagline ? '<p class="fragrance-quiz__result-tagline">' + escapeHtml(product.tagline) + '</p>' : '') +
          '<div class="fragrance-quiz__result-price">' + priceMarkup + '</div>' +
          '<a href="' + escapeHtml(product.url) + '" class="fragrance-quiz__result-button">' + escapeHtml(shopLabel) + '</a>' +
        '</div>';

      questionsPanel.hidden = true;
      resultPanel.hidden = false;
      spawnConfetti();
    }

    startButton.addEventListener('click', () => {
      startPanel.hidden = true;
      questionsPanel.hidden = false;
      currentIndex = 0;
      answers = [];
      showQuestion(0);
    });

    root.addEventListener('click', (e) => {
      const option = e.target.closest('[data-quiz-option]');
      if (!option) return;

      answers[currentIndex] = option.getAttribute('data-tag');

      if (currentIndex < questions.length - 1) {
        currentIndex += 1;
        showQuestion(currentIndex);
      } else {
        renderResult();
      }
    });

    if (retakeButton) {
      retakeButton.addEventListener('click', () => {
        answers = [];
        currentIndex = 0;
        resultPanel.hidden = true;
        startPanel.hidden = false;
        showQuestion(0);
      });
    }
  });
{% endjavascript %}

