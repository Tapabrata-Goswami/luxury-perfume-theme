<section class="hero">
  <div class="hero__content">
    {%- if section.settings.eyebrow != blank -%}
      <div class="hero__eyebrow">{{ section.settings.eyebrow }}</div>
    {%- endif -%}

    <h1 class="hero__heading">
      {{ section.settings.heading_line1 }}<br>
      {{ section.settings.heading_line2 }}
      {%- if section.settings.heading_emphasis != blank %}
        <span class="hero__heading-emphasis">{{ section.settings.heading_emphasis }}</span>
      {%- endif %}
    </h1>

    {%- if section.settings.body != blank -%}
      <p class="hero__body">{{ section.settings.body }}</p>
    {%- endif -%}

    <div class="hero__actions">
      {%- if section.settings.primary_cta_text != blank -%}
        <a href="{{ section.settings.primary_cta_link | default: '#' }}" class="hero__button hero__button--primary">
          {{- section.settings.primary_cta_text -}}
        </a>
      {%- endif -%}
      {%- if section.settings.secondary_cta_text != blank -%}
        <a href="{{ section.settings.secondary_cta_link | default: '#' }}" class="hero__button hero__button--secondary">
          {{- section.settings.secondary_cta_text -}}
        </a>
      {%- endif -%}
    </div>
  </div>

  <div class="hero__media">
    {% content_for 'blocks' %}

    <span class="hero__spark" style="--top: 18%; --left: 22%; --size: 4px; --delay: 0;"></span>
    <span class="hero__spark" style="--top: 30%; --left: 70%; --size: 3px; --delay: 1;"></span>
    <span class="hero__spark" style="--top: 60%; --left: 15%; --size: 5px; --delay: 2;"></span>
    <span class="hero__spark" style="--top: 75%; --left: 78%; --size: 3px; --delay: 3;"></span>
    <span class="hero__spark" style="--top: 12%; --left: 55%; --size: 3px; --delay: 4;"></span>
    <span class="hero__spark" style="--top: 45%; --left: 85%; --size: 4px; --delay: 5;"></span>
    <span class="hero__spark" style="--top: 85%; --left: 40%; --size: 3px; --delay: 6;"></span>
    <span class="hero__spark" style="--top: 52%; --left: 50%; --size: 4px; --delay: 7;"></span>
    <span class="hero__spark" style="--top: 8%; --left: 85%; --size: 3px; --delay: 8;"></span>
    <span class="hero__spark" style="--top: 38%; --left: 8%; --size: 3px; --delay: 9;"></span>
  </div>
</section>

{% stylesheet %}
  .hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: stretch;
    min-height: 620px;
    border-bottom: 1px solid var(--color-border);
  }

  .hero__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 2.5rem 0;
  }

  .hero__eyebrow {
    color: var(--color-gold);
    font-size: 13px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    margin-bottom: 1.375rem;
  }

  .hero__heading {
    font-family: var(--font-heading--family);
    font-weight: 500;
    font-size: 58px;
    line-height: 1.08;
    margin: 0 0 1.625rem;
  }

  .hero__heading-emphasis {
    color: var(--color-gold);
    font-style: italic;
  }

  .hero__body {
    font-size: 16px;
    line-height: 1.7;
    color: #c9beac;
    max-width: 420px;
    margin: 0 0 2.5rem;
  }

  .hero__actions {
    display: flex;
    gap: 1.25rem;
  }

  .hero__button {
    text-decoration: none;
    padding: 1rem 2.25rem;
    font-size: 13px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border-radius: 4px;
    transition: background-color 0.25s ease, color 0.25s ease, border-color 0.25s ease, transform 0.25s ease;
  }

  .hero__button--primary {
    background: var(--color-gold-dark);
    color: var(--color-background);
    font-weight: 600;
    border: 1px solid var(--color-gold-dark);
  }

  .hero__button--primary:hover {
    background: var(--color-gold);
    border-color: var(--color-gold);
    transform: translateY(-2px);
  }

  .hero__button--secondary {
    border: 1px solid var(--color-gold-dark);
    color: var(--color-gold);
    background: transparent;
  }

  .hero__button--secondary:hover {
    background: var(--color-gold-dark);
    color: var(--color-background);
    transform: translateY(-2px);
  }

  .hero__media {
    position: relative;
    background: var(--color-background);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero__spark {
    position: absolute;
    z-index: 2;
    top: var(--top);
    left: var(--left);
    width: var(--size);
    height: var(--size);
    border-radius: 50%;
    background: #fff8e6;
    box-shadow: 0 0 10px 3px rgba(255, 248, 230, 0.9);
    animation: hero-twinkle 2.4s ease-in-out infinite;
    animation-delay: calc(var(--delay) * 0.25s);
  }

  @keyframes hero-twinkle {
    0%,
    100% {
      opacity: 0.15;
      transform: scale(0.6);
    }
    50% {
      opacity: 1;
      transform: scale(1.3);
    }
  }

  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
    }

    .hero__media {
      min-height: 420px;
    }
  }
{% endstylesheet %}

{% javascript %}
  document.querySelectorAll('.hero__media').forEach((media) => {
    const slides = Array.from(media.querySelectorAll('.hero__slide'));
    if (slides.length < 2) {
      if (slides.length === 1) slides[0].classList.add('is-active');
      return;
    }

    let current = 0;
    slides[current].classList.add('is-active');

    setInterval(() => {
      const next = (current + 1) % slides.length;
      slides[current].classList.remove('is-active');
      slides[next].classList.add('is-active');
      current = next;
    }, 4500);
  });
{% endjavascript %}

